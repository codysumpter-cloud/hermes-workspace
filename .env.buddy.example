# Buddy Workspace — Environment Variables
#
# Copy this to .env when running the Prismtek/Buddy-branded workspace:
#   cp .env.buddy.example .env

# ═══════════════════════════════════════════════════════════════
# Buddy/Hermes backend connection
# ═══════════════════════════════════════════════════════════════

# Buddy-compatible gateway URL.
# Works with buddy-agent, Hermes Agent, or any OpenAI-compatible gateway that
# exposes /v1/chat/completions. For Docker Compose, this defaults to
# http://buddy-agent:8642.
# BUDDY_API_URL=http://127.0.0.1:8642

# Optional dashboard URL. Enhanced workspace panes use dashboard-backed APIs
# for sessions, skills, config, jobs, conductor, kanban, and MCP where available.
# BUDDY_DASHBOARD_URL=http://127.0.0.1:9119

# Optional gateway bearer token. Must match API_SERVER_KEY on the agent side
# when the gateway is authenticated.
# BUDDY_API_TOKEN=change-me

# Optional explicit local paths.
# BUDDY_HOME=/home/workspace/.hermes
# BUDDY_WORKSPACE_DIR=/workspace
# BUDDY_WORKSPACE_STATE_DIR=/home/workspace/.hermes/workspace
# BUDDY_AGENT_PATH=/path/to/buddy-agent

# Optional default model for OpenAI-compatible chat calls.
# BUDDY_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b

# ═══════════════════════════════════════════════════════════════
# Workspace security
# ═══════════════════════════════════════════════════════════════

# Required when HOST is non-loopback, including Docker's default HOST=0.0.0.0.
# Pick a strong secret.
BUDDY_PASSWORD=change-me-to-a-strong-secret

# Bind address. Keep 127.0.0.1 for local-only dev. Use 0.0.0.0 only behind
# auth/reverse proxy/Tailscale and with BUDDY_PASSWORD set.
# HOST=127.0.0.1

# Plain HTTP LAN deployments need COOKIE_SECURE=0 or browsers will drop auth
# cookies when NODE_ENV=production.
# COOKIE_SECURE=0

# Set only behind a trusted proxy that sanitizes x-forwarded-for / x-real-ip.
# TRUST_PROXY=1

# Last-resort escape hatch. Not recommended.
# BUDDY_ALLOW_INSECURE_REMOTE=0

# ═══════════════════════════════════════════════════════════════
# Provider keys passed through to the agent runtime
# ═══════════════════════════════════════════════════════════════

# Uncomment only what you actually use.
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-v1-...
# GOOGLE_API_KEY=AIza...
# NVIDIA_API_KEY=nvapi-...

# Local models such as Ollama/LM Studio generally do not need a key; point the
# agent config at the local OpenAI-compatible endpoint instead.
